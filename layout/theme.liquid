<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  {% render 'meta-tags' %}
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preload" href="{{ 'application.css' | asset_url }}" as="style">
  {{ 'application.css' | asset_url | stylesheet_tag }}

  {%- unless settings.font_heading.system? -%}
    {%- assign font_heading_url = settings.font_heading | font_url -%}
    {%- unless font_heading_url contains 'Liquid error' -%}
      <link rel="preload" as="font" href="{{ font_heading_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
  {%- endunless -%}

  {{ settings.font_heading | font_face: font_display: 'swap' }}
  {{ settings.font_body | font_face: font_display: 'swap' }}

  <style>
    :root {
      --color-primary: {{ settings.color_primary }};
      --color-secondary: {{ settings.color_secondary }};
      --color-accent: {{ settings.color_accent }};
      --color-background: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
      --border-radius: {{ settings.border_radius }}px;
      --font-heading: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
      --font-body: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
    }
  </style>

  {%- if settings.sky_enabled -%}
    {%- comment -%}
      Sky-Pattern background-image: aktuelle Setting-Farbe/Opacity in das SVG-Snippet einsetzen
      und als Data-URI emitten. Manuelles Percent-Encoding (statt url_encode) weil:
      - url_encode würde Spaces als '+' kodieren — Data-URIs decoden '+' nicht zu Space
      - Wenn '#' bereits vor url_encode zu '%23' ersetzt wäre, würde url_encode '%23' zu '%2523' doppel-encoden
    {%- endcomment -%}
    {%- assign sky_color = settings.sky_color | default: '#0E7CB4' -%}
    {%- assign sky_opacity_value = settings.sky_opacity | default: 40 | divided_by: 100.0 -%}
    {%- capture sky_svg_raw -%}{% render 'sky-pattern-svg' %}{%- endcapture -%}
    {%- assign sky_svg = sky_svg_raw | replace: '__COLOR__', sky_color | replace: '__OPACITY__', sky_opacity_value | strip_newlines | replace: '"', "'" | replace: '<', '%3C' | replace: '>', '%3E' | replace: '#', '%23' | replace: ' ', '%20' -%}
    <style>
      body.has-sky-bg {
        background-image: url("data:image/svg+xml,{{ sky_svg }}");
      }
    </style>
  {%- endif -%}

  <script>
    window.themeSettings = {
      freeShippingThreshold: {{ settings.free_shipping_threshold | times: 100 }},
      cartUpsellEnabled: {{ settings.cart_upsell_enabled }},
      moneyFormat: {{ shop.money_format | json }}
    };
  </script>

  {% render 'schema-organization' %}
  {% render 'schema-website' %}

  {{ content_for_header }}
</head>
<body class="font-body text-primary bg-[var(--color-background)]{% if settings.sky_enabled %} has-sky-bg{% if settings.sky_parallax %} has-sky-parallax{% endif %}{% endif %}">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-white focus:text-primary">
    {{ 'general.skip_to_content' | t }}
  </a>

  {% sections 'header-group' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}
  {% section 'cart-drawer' %}

  <script src="{{ 'base.js' | asset_url }}" type="module"></script>
</body>
</html>
