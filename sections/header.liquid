{%- comment -%}
  Premium Header with Hybrid Mega Menu (Option C)
  Desktop: Category image tiles + dynamic hover preview + product count
  Mobile: Full-screen drawer with thumbnails + drill-down navigation
{%- endcomment -%}

<header
  class="sticky top-0 z-40 bg-white transition-all duration-300"
  x-data="{
    mobileOpen: false,
    mobileLevel: 0,
    mobileActiveMenu: null,
    activeDesktop: null,
    hoveredChild: null,
    scrolled: false
  }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 10 }, { passive: true })"
  :class="scrolled && 'shadow-md'"
>
  {%- comment -%} Announcement Bar {%- endcomment -%}
  {%- if section.settings.announcement_text != blank -%}
    <div class="bg-primary text-white text-center py-2 text-xs sm:text-sm tracking-wide transition-all duration-300" :class="scrolled && 'hidden'">
      {%- if section.settings.announcement_link != blank -%}
        <a href="{{ section.settings.announcement_link }}" class="hover:underline">{{ section.settings.announcement_text }}</a>
      {%- else -%}
        <p>{{ section.settings.announcement_text }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="border-b border-gray-100">
    <div class="container">
      <div class="flex items-center justify-between transition-all duration-300" :class="scrolled ? 'h-14' : 'h-16 lg:h-20'">

        {%- comment -%} Mobile: Hamburger {%- endcomment -%}
        <button
          class="lg:hidden p-2 -ml-2 hover:bg-gray-50 rounded-lg transition-colors"
          @click="mobileOpen = true; mobileLevel = 0; mobileActiveMenu = null"
          aria-label="{{ 'accessibility.open_menu' | t }}"
        >
          {% render 'icon', name: 'menu', size: 24 %}
        </button>

        {%- comment -%} Logo {%- endcomment -%}
        <a href="/" class="flex-shrink-0 relative z-10">
          {%- if settings.logo != blank -%}
            {% render 'image',
              image: settings.logo,
              alt: shop.name,
              width: settings.logo_width,
              sizes: '56px',
              class: 'h-8 lg:h-10 w-auto transition-all duration-300',
              priority: true
            %}
          {%- else -%}
            <span class="text-xl lg:text-2xl font-heading font-bold tracking-tight">{{ shop.name }}</span>
          {%- endif -%}
        </a>

        {%- comment -%} ===== DESKTOP NAVIGATION ===== {%- endcomment -%}
        <nav class="hidden lg:flex items-center gap-0.5 h-full" aria-label="Main navigation">
          {%- for link in section.settings.menu.links -%}
            {%- if link.links.size > 0 -%}
              <div
                class="static h-full flex items-center"
                @mouseenter="activeDesktop = '{{ link.title | handleize }}'; hoveredChild = null"
                @mouseleave="activeDesktop = null; hoveredChild = null"
              >
                <button
                  class="relative flex items-center gap-1 px-3 xl:px-4 py-2 text-[13px] font-semibold tracking-wide uppercase transition-colors"
                  :class="activeDesktop === '{{ link.title | handleize }}' ? 'text-accent' : 'text-primary hover:text-accent'"
                  @click="activeDesktop = activeDesktop === '{{ link.title | handleize }}' ? null : '{{ link.title | handleize }}'"
                  :aria-expanded="activeDesktop === '{{ link.title | handleize }}'"
                >
                  {{ link.title }}
                  <svg class="w-3 h-3 transition-transform duration-200" :class="activeDesktop === '{{ link.title | handleize }}' && 'rotate-180'" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>

                  {%- comment -%} Active underline {%- endcomment -%}
                  <span
                    class="absolute bottom-0 left-3 right-3 h-0.5 bg-accent transform origin-left transition-transform duration-200"
                    :class="activeDesktop === '{{ link.title | handleize }}' ? 'scale-x-100' : 'scale-x-0'"
                  ></span>
                </button>

                {%- comment -%} ===== MEGA MENU PANEL ===== {%- endcomment -%}
                <div
                  class="absolute left-0 right-0 top-full w-full"
                  x-show="activeDesktop === '{{ link.title | handleize }}'"
                  x-transition:enter="transition ease-out duration-250"
                  x-transition:enter-start="opacity-0 -translate-y-3"
                  x-transition:enter-end="opacity-100 translate-y-0"
                  x-transition:leave="transition ease-in duration-150"
                  x-transition:leave-start="opacity-100 translate-y-0"
                  x-transition:leave-end="opacity-0 -translate-y-3"
                  x-cloak
                >
                  <div class="bg-white border-t-2 border-accent/20 shadow-2xl">
                    <div class="container py-8">
                      <div class="grid grid-cols-12 gap-6">

                        {%- comment -%} LEFT: Category tile grid — 8 cols {%- endcomment -%}
                        <div class="col-span-8">
                          <div class="grid grid-cols-3 xl:grid-cols-4 gap-3">
                            {%- for child_link in link.links -%}
                              {%- comment -%} Get collection from URL for product image + count {%- endcomment -%}
                              {%- assign child_handle = child_link.url | split: '/collections/' | last | split: '?' | first -%}
                              {%- assign child_collection = collections[child_handle] -%}
                              {%- assign child_image = child_collection.image -%}
                              {%- unless child_image -%}
                                {%- if child_collection.products.size > 0 -%}
                                  {%- assign child_image = child_collection.products.first.featured_image -%}
                                {%- endif -%}
                              {%- endunless -%}

                              <a
                                href="{{ child_link.url }}"
                                class="group relative rounded-xl overflow-hidden aspect-square bg-gray-50 block"
                                @mouseenter="hoveredChild = { title: '{{ child_link.title | escape }}', handle: '{{ child_handle }}', count: '{{ child_collection.products_count | default: 0 }}' }"
                              >
                                {%- if child_image -%}
                                  {% render 'image',
                                    image: child_image,
                                    alt: child_link.title,
                                    class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-110',
                                    sizes: '200px',
                                    width: 200
                                  %}
                                {%- else -%}
                                  <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200"></div>
                                {%- endif -%}

                                {%- comment -%} Overlay {%- endcomment -%}
                                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent group-hover:from-black/80 transition-colors duration-300">
                                  <div class="absolute bottom-0 left-0 right-0 p-3">
                                    <p class="text-white font-semibold text-sm leading-tight">{{ child_link.title }}</p>
                                    {%- if child_collection.products_count and child_collection.products_count > 0 -%}
                                      <p class="text-white/60 text-xs mt-0.5">{{ child_collection.products_count }} Produkte</p>
                                    {%- endif -%}
                                  </div>
                                </div>

                                {%- comment -%} Bestseller badge for collections with many products {%- endcomment -%}
                                {%- if child_collection.products_count > 15 -%}
                                  <div class="absolute top-2 right-2 bg-accent text-white text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full">
                                    Beliebt
                                  </div>
                                {%- endif -%}
                              </a>
                            {%- endfor -%}
                          </div>

                          {%- comment -%} View All link {%- endcomment -%}
                          <div class="mt-5 flex items-center justify-between">
                            <a href="{{ link.url | default: '#' }}" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent hover:underline underline-offset-4">
                              Alle {{ link.title }} anzeigen
                              {% render 'icon', name: 'chevron-right', size: 14 %}
                            </a>
                          </div>
                        </div>

                        {%- comment -%} RIGHT: Dynamic preview — 4 cols {%- endcomment -%}
                        <div class="col-span-4">
                          <div class="rounded-2xl overflow-hidden bg-gray-50 aspect-[3/4] relative">

                            {%- comment -%} Default: Promo image from block OR first child collection image {%- endcomment -%}
                            <div x-show="!hoveredChild" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="absolute inset-0">
                              {%- assign has_promo = false -%}
                              {%- for block in section.blocks -%}
                                {%- if block.type == 'mega_menu_image' and block.settings.menu_title == link.title -%}
                                  {%- assign has_promo = true -%}
                                  {%- if block.settings.image != blank -%}
                                    {% render 'image',
                                      image: block.settings.image,
                                      alt: block.settings.image_heading,
                                      class: 'w-full h-full object-cover',
                                      sizes: '400px'
                                    %}
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent flex flex-col justify-end p-6">
                                      {%- if block.settings.image_heading != blank -%}
                                        <p class="text-white font-bold text-xl mb-1">{{ block.settings.image_heading }}</p>
                                      {%- endif -%}
                                      {%- if block.settings.image_text != blank -%}
                                        <p class="text-white/70 text-sm mb-3">{{ block.settings.image_text }}</p>
                                      {%- endif -%}
                                      <span class="inline-flex items-center gap-1 text-white text-sm font-medium">
                                        Jetzt entdecken
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                                      </span>
                                    </div>
                                  {%- endif -%}
                                {%- endif -%}
                              {%- endfor -%}

                              {%- unless has_promo -%}
                                {%- comment -%} Fallback: first child collection image {%- endcomment -%}
                                {%- if link.links.size > 0 -%}
                                  {%- assign first_child_handle = link.links.first.url | split: '/collections/' | last | split: '?' | first -%}
                                  {%- assign first_child_col = collections[first_child_handle] -%}
                                  {%- assign fallback_img = first_child_col.image -%}
                                  {%- unless fallback_img -%}
                                    {%- if first_child_col.products.size > 0 -%}
                                      {%- assign fallback_img = first_child_col.products.first.featured_image -%}
                                    {%- endif -%}
                                  {%- endunless -%}
                                  {%- if fallback_img -%}
                                    {% render 'image',
                                      image: fallback_img,
                                      alt: link.title,
                                      class: 'w-full h-full object-cover',
                                      sizes: '400px'
                                    %}
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent flex flex-col justify-end p-6">
                                      <p class="text-white font-bold text-xl mb-1">{{ link.title }}</p>
                                      <p class="text-white/60 text-sm">Kollektion entdecken</p>
                                    </div>
                                  {%- endif -%}
                                {%- endif -%}
                              {%- endunless -%}
                            </div>

                            {%- comment -%} Hover state: show hovered child info {%- endcomment -%}
                            {%- for child_link in link.links -%}
                              {%- assign ch_handle = child_link.url | split: '/collections/' | last | split: '?' | first -%}
                              {%- assign ch_col = collections[ch_handle] -%}
                              {%- assign ch_img = ch_col.image -%}
                              {%- unless ch_img -%}
                                {%- if ch_col.products.size > 0 -%}
                                  {%- assign ch_img = ch_col.products.first.featured_image -%}
                                {%- endif -%}
                              {%- endunless -%}

                              <div
                                x-show="hoveredChild && hoveredChild.handle === '{{ ch_handle }}'"
                                x-transition:enter="transition ease-out duration-300"
                                x-transition:enter-start="opacity-0 scale-105"
                                x-transition:enter-end="opacity-100 scale-100"
                                class="absolute inset-0"
                              >
                                {%- if ch_img -%}
                                  {% render 'image',
                                    image: ch_img,
                                    alt: child_link.title,
                                    class: 'w-full h-full object-cover',
                                    sizes: '400px'
                                  %}
                                {%- else -%}
                                  <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200"></div>
                                {%- endif -%}
                                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent flex flex-col justify-end p-6">
                                  <p class="text-white font-bold text-xl mb-1">{{ child_link.title }}</p>
                                  {%- if ch_col.products_count -%}
                                    <p class="text-white/60 text-sm mb-3">{{ ch_col.products_count }} Produkte</p>
                                  {%- endif -%}
                                  {%- if ch_col.products.size > 0 -%}
                                    <p class="text-white/80 text-sm">ab {{ ch_col.products.first.price | money }}</p>
                                  {%- endif -%}
                                  <span class="inline-flex items-center gap-1 text-white text-sm font-medium mt-2">
                                    Kollektion ansehen
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                                  </span>
                                </div>
                              </div>
                            {%- endfor -%}
                          </div>
                        </div>

                      </div>
                    </div>
                  </div>
                </div>
              </div>
            {%- else -%}
              <a href="{{ link.url }}" class="relative px-3 xl:px-4 py-2 text-[13px] font-semibold tracking-wide uppercase hover:text-accent transition-colors group">
                {{ link.title }}
                <span class="absolute bottom-0 left-3 right-3 h-0.5 bg-accent transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-200"></span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </nav>

        {%- comment -%} Right: Account + Cart {%- endcomment -%}
        <div class="flex items-center gap-1">
          <a href="{{ routes.account_url }}" class="hidden lg:flex p-2 hover:bg-gray-50 rounded-lg transition-colors" aria-label="Account">
            {% render 'icon', name: 'account', size: 22 %}
          </a>
          <button
            class="p-2 relative hover:bg-gray-50 rounded-lg transition-colors"
            @click="$store.cart.open()"
            aria-label="{{ 'accessibility.open_cart' | t }}"
          >
            {% render 'icon', name: 'cart', size: 22 %}
            <span
              x-show="$store.cart.itemCount > 0"
              x-text="$store.cart.itemCount"
              class="absolute -top-0.5 -right-0.5 bg-accent text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center"
              x-cloak
            ></span>
          </button>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ===== MOBILE MENU ===== {%- endcomment -%}
  <div class="fixed inset-0 z-50 lg:hidden" x-show="mobileOpen" x-cloak>

    {%- comment -%} Backdrop {%- endcomment -%}
    <div
      class="absolute inset-0 bg-black/50 backdrop-blur-sm"
      x-show="mobileOpen"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      @click="mobileOpen = false"
    ></div>

    {%- comment -%} Drawer {%- endcomment -%}
    <div
      class="absolute left-0 top-0 bottom-0 w-full max-w-sm bg-white shadow-2xl flex flex-col overflow-hidden"
      x-show="mobileOpen"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="-translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="-translate-x-full"
      @keydown.escape.window="mobileOpen = false"
    >
      {%- comment -%} Header {%- endcomment -%}
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        {%- if settings.logo != blank -%}
          {% render 'image', image: settings.logo, alt: shop.name, width: 100, class: 'h-7 w-auto' %}
        {%- else -%}
          <span class="font-heading font-bold text-lg">{{ shop.name }}</span>
        {%- endif -%}
        <button @click="mobileOpen = false" class="p-2 hover:bg-gray-50 rounded-lg" aria-label="{{ 'accessibility.close_menu' | t }}">
          {% render 'icon', name: 'close', size: 22 %}
        </button>
      </div>

      <div class="flex-1 overflow-y-auto relative">

        {%- comment -%} Level 0: Main items with thumbnails {%- endcomment -%}
        <div
          class="absolute inset-0 overflow-y-auto transition-transform duration-300"
          :class="mobileLevel > 0 ? '-translate-x-full' : 'translate-x-0'"
        >
          <nav class="py-2" aria-label="Mobile navigation">
            <ul>
              {%- for link in section.settings.menu.links -%}
                <li>
                  {%- if link.links.size > 0 -%}
                    {%- comment -%} Get thumbnail from first child collection {%- endcomment -%}
                    {%- assign mob_handle = link.links.first.url | split: '/collections/' | last | split: '?' | first -%}
                    {%- assign mob_col = collections[mob_handle] -%}
                    {%- assign mob_img = mob_col.image -%}
                    {%- unless mob_img -%}
                      {%- if mob_col.products.size > 0 -%}
                        {%- assign mob_img = mob_col.products.first.featured_image -%}
                      {%- endif -%}
                    {%- endunless -%}

                    <button
                      class="flex items-center gap-3 w-full px-5 py-3 hover:bg-gray-50 transition-colors"
                      @click="mobileLevel = 1; mobileActiveMenu = '{{ link.title | handleize }}'"
                    >
                      {%- if mob_img -%}
                        <div class="w-11 h-11 rounded-lg overflow-hidden flex-shrink-0 bg-gray-100">
                          {% render 'image', image: mob_img, alt: link.title, class: 'w-full h-full object-cover', width: 44, sizes: '44px' %}
                        </div>
                      {%- else -%}
                        <div class="w-11 h-11 rounded-lg bg-gray-100 flex-shrink-0"></div>
                      {%- endif -%}
                      <span class="flex-1 text-left text-[15px] font-medium">{{ link.title }}</span>
                      {% render 'icon', name: 'chevron-right', size: 18 %}
                    </button>
                  {%- else -%}
                    <a href="{{ link.url }}" class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition-colors">
                      <div class="w-11 h-11 rounded-lg bg-gray-100 flex-shrink-0 flex items-center justify-center">
                        {% render 'icon', name: 'chevron-right', size: 16 %}
                      </div>
                      <span class="text-[15px] font-medium">{{ link.title }}</span>
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>

            {%- if section.settings.mobile_secondary_menu != blank -%}
              <div class="mt-3 pt-3 border-t border-gray-100 px-5">
                {%- for link in section.settings.mobile_secondary_menu.links -%}
                  <a href="{{ link.url }}" class="block py-2.5 text-sm text-gray-500 hover:text-primary">{{ link.title }}</a>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="mt-6 px-5 flex items-center gap-4">
              {%- if settings.social_instagram != blank -%}
                <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" class="text-gray-400 hover:text-primary" aria-label="Instagram">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_tiktok != blank -%}
                <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" class="text-gray-400 hover:text-primary" aria-label="TikTok">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                </a>
              {%- endif -%}
            </div>
          </nav>
        </div>

        {%- comment -%} Level 1: Sub-menus with thumbnails {%- endcomment -%}
        {%- for link in section.settings.menu.links -%}
          {%- if link.links.size > 0 -%}
            <div
              class="absolute inset-0 overflow-y-auto transition-transform duration-300"
              :class="mobileLevel === 1 && mobileActiveMenu === '{{ link.title | handleize }}' ? 'translate-x-0' : 'translate-x-full'"
            >
              <button
                class="flex items-center gap-2 w-full px-5 py-4 text-sm font-medium text-gray-500 hover:bg-gray-50 border-b border-gray-100"
                @click="mobileLevel = 0; mobileActiveMenu = null"
              >
                <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                Zurück
              </button>

              <div class="px-5 py-3">
                <h3 class="text-lg font-heading font-bold">{{ link.title }}</h3>
              </div>

              <ul class="px-3">
                {%- for child_link in link.links -%}
                  {%- assign mob_ch_handle = child_link.url | split: '/collections/' | last | split: '?' | first -%}
                  {%- assign mob_ch_col = collections[mob_ch_handle] -%}
                  {%- assign mob_ch_img = mob_ch_col.image -%}
                  {%- unless mob_ch_img -%}
                    {%- if mob_ch_col.products.size > 0 -%}
                      {%- assign mob_ch_img = mob_ch_col.products.first.featured_image -%}
                    {%- endif -%}
                  {%- endunless -%}

                  <li>
                    <a href="{{ child_link.url }}" class="flex items-center gap-3 px-2 py-2.5 rounded-lg hover:bg-gray-50 transition-colors">
                      {%- if mob_ch_img -%}
                        <div class="w-12 h-12 rounded-lg overflow-hidden flex-shrink-0 bg-gray-100">
                          {% render 'image', image: mob_ch_img, alt: child_link.title, class: 'w-full h-full object-cover', width: 48, sizes: '48px' %}
                        </div>
                      {%- else -%}
                        <div class="w-12 h-12 rounded-lg bg-gray-100 flex-shrink-0"></div>
                      {%- endif -%}
                      <div class="flex-1 min-w-0">
                        <p class="text-[15px] font-medium">{{ child_link.title }}</p>
                        {%- if mob_ch_col.products_count and mob_ch_col.products_count > 0 -%}
                          <p class="text-xs text-gray-400">{{ mob_ch_col.products_count }} Produkte</p>
                        {%- endif -%}
                      </div>
                      {% render 'icon', name: 'chevron-right', size: 16 %}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>

              {%- if link.url != '#' -%}
                <div class="px-5 py-4 mt-2">
                  <a href="{{ link.url }}" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
                    Alle {{ link.title }} anzeigen
                    {% render 'icon', name: 'chevron-right', size: 14 %}
                  </a>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Kostenloser Versand ab 150€ | Made in Italy"
    },
    {
      "type": "url",
      "id": "announcement_link",
      "label": "Announcement Link"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Hauptmenü",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "mobile_secondary_menu",
      "label": "Mobile: Sekundäres Menü (z.B. Über uns, Kontakt)"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu_image",
      "name": "Mega Menu Promo-Bild",
      "settings": [
        {
          "type": "text",
          "id": "menu_title",
          "label": "Menüpunkt-Titel (muss exakt übereinstimmen)",
          "info": "z.B. 'Sitzmöbel' — wenn leer, wird automatisch das erste Produktbild der Kategorie verwendet"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Promo-Bild"
        },
        {
          "type": "text",
          "id": "image_heading",
          "label": "Überschrift",
          "default": "Neue Kollektion"
        },
        {
          "type": "text",
          "id": "image_text",
          "label": "Text",
          "default": "Jetzt entdecken"
        },
        {
          "type": "url",
          "id": "image_link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
