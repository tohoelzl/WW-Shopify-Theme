{%- comment -%}
  Premium Header with Mega Menu
  Supports multi-level navigation with promotional images.
  Desktop: Full-width dropdown panels with columns + featured image
  Mobile: Full-screen drawer with drill-down levels
{%- endcomment -%}

<header
  class="sticky top-0 z-40 bg-white transition-shadow duration-300"
  x-data="{
    mobileOpen: false,
    mobileLevel: 0,
    mobileActiveMenu: null,
    activeDesktop: null,
    scrolled: false
  }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 10 })"
  :class="scrolled && 'shadow-md'"
>
  {%- comment -%} Announcement Bar (inline for tight coupling) {%- endcomment -%}
  {%- if section.settings.announcement_text != blank -%}
    <div class="bg-primary text-white text-center py-2 text-xs sm:text-sm tracking-wide">
      {%- if section.settings.announcement_link != blank -%}
        <a href="{{ section.settings.announcement_link }}" class="hover:underline">{{ section.settings.announcement_text }}</a>
      {%- else -%}
        <p>{{ section.settings.announcement_text }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="border-b border-gray-100">
    <div class="container">
      <div class="flex items-center justify-between h-16 lg:h-20">

        {%- comment -%} Mobile: Hamburger {%- endcomment -%}
        <button
          class="lg:hidden p-2 -ml-2 hover:bg-gray-50 rounded-lg transition-colors"
          @click="mobileOpen = true; mobileLevel = 0; mobileActiveMenu = null"
          aria-label="{{ 'accessibility.open_menu' | t }}"
        >
          {% render 'icon', name: 'menu', size: 24 %}
        </button>

        {%- comment -%} Logo {%- endcomment -%}
        <a href="/" class="flex-shrink-0 relative z-10">
          {%- if settings.logo != blank -%}
            {% render 'image',
              image: settings.logo,
              alt: shop.name,
              width: settings.logo_width,
              class: 'h-8 lg:h-10 w-auto',
              priority: true
            %}
          {%- else -%}
            <span class="text-xl lg:text-2xl font-heading font-bold tracking-tight">{{ shop.name }}</span>
          {%- endif -%}
        </a>

        {%- comment -%} Desktop Navigation {%- endcomment -%}
        <nav class="hidden lg:flex items-center gap-1 h-full" aria-label="Main navigation">
          {%- for link in section.settings.menu.links -%}
            {%- if link.links.size > 0 -%}
              <div
                class="relative h-full flex items-center"
                @mouseenter="activeDesktop = '{{ link.title | handleize }}'"
                @mouseleave="activeDesktop = null"
              >
                <button
                  class="flex items-center gap-1 px-4 py-2 text-sm font-medium tracking-wide uppercase hover:text-accent transition-colors"
                  :class="activeDesktop === '{{ link.title | handleize }}' && 'text-accent'"
                  @click="activeDesktop = activeDesktop === '{{ link.title | handleize }}' ? null : '{{ link.title | handleize }}'"
                  :aria-expanded="activeDesktop === '{{ link.title | handleize }}'"
                >
                  {{ link.title }}
                  <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="activeDesktop === '{{ link.title | handleize }}' && 'rotate-180'" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
                </button>

                {%- comment -%} Mega Menu Panel {%- endcomment -%}
                <div
                  class="absolute left-1/2 top-full w-screen -translate-x-1/2"
                  x-show="activeDesktop === '{{ link.title | handleize }}'"
                  x-transition:enter="transition ease-out duration-200"
                  x-transition:enter-start="opacity-0 -translate-y-2"
                  x-transition:enter-end="opacity-100 translate-y-0"
                  x-transition:leave="transition ease-in duration-150"
                  x-transition:leave-start="opacity-100 translate-y-0"
                  x-transition:leave-end="opacity-0 -translate-y-2"
                  x-cloak
                  @click.outside="activeDesktop = null"
                >
                  <div class="bg-white border-t border-gray-100 shadow-xl">
                    <div class="container py-8">
                      <div class="grid grid-cols-12 gap-8">
                        {%- comment -%} Menu Columns — take 8 cols {%- endcomment -%}
                        <div class="col-span-8">
                          <div class="grid grid-cols-3 gap-x-8 gap-y-6">
                            {%- for child_link in link.links -%}
                              <div>
                                <a href="{{ child_link.url }}" class="text-sm font-bold uppercase tracking-wider text-primary hover:text-accent transition-colors">
                                  {{ child_link.title }}
                                </a>
                                {%- if child_link.links.size > 0 -%}
                                  <ul class="mt-3 space-y-2">
                                    {%- for grandchild in child_link.links -%}
                                      <li>
                                        <a href="{{ grandchild.url }}" class="text-sm text-gray-500 hover:text-primary transition-colors">
                                          {{ grandchild.title }}
                                        </a>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                {%- endif -%}
                              </div>
                            {%- endfor -%}
                          </div>

                          {%- comment -%} View All link {%- endcomment -%}
                          {%- if link.url != '#' -%}
                            <a href="{{ link.url }}" class="inline-flex items-center gap-1 mt-6 text-sm font-medium text-accent hover:underline">
                              Alle {{ link.title }} anzeigen
                              {% render 'icon', name: 'chevron-right', size: 14 %}
                            </a>
                          {%- endif -%}
                        </div>

                        {%- comment -%} Promotional Image — 4 cols {%- endcomment -%}
                        <div class="col-span-4">
                          {%- assign block_index = forloop.index0 -%}
                          {%- for block in section.blocks -%}
                            {%- if block.type == 'mega_menu_image' and block.settings.menu_title == link.title -%}
                              <a href="{{ block.settings.image_link | default: link.url }}" class="block group rounded-lg overflow-hidden relative aspect-[4/3]">
                                {%- if block.settings.image != blank -%}
                                  {% render 'image',
                                    image: block.settings.image,
                                    alt: block.settings.image_heading,
                                    class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
                                    sizes: '400px'
                                  %}
                                {%- else -%}
                                  <div class="w-full h-full bg-secondary"></div>
                                {%- endif -%}
                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex items-end p-5">
                                  <div>
                                    {%- if block.settings.image_heading != blank -%}
                                      <p class="text-white font-bold text-lg">{{ block.settings.image_heading }}</p>
                                    {%- endif -%}
                                    {%- if block.settings.image_text != blank -%}
                                      <p class="text-white/80 text-sm mt-1">{{ block.settings.image_text }}</p>
                                    {%- endif -%}
                                  </div>
                                </div>
                              </a>
                            {%- endif -%}
                          {%- endfor -%}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            {%- else -%}
              <a href="{{ link.url }}" class="px-4 py-2 text-sm font-medium tracking-wide uppercase hover:text-accent transition-colors">
                {{ link.title }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </nav>

        {%- comment -%} Right: Search + Account + Cart {%- endcomment -%}
        <div class="flex items-center gap-1 sm:gap-2">
          <a href="{{ routes.account_url }}" class="hidden lg:flex p-2 hover:bg-gray-50 rounded-lg transition-colors" aria-label="Account">
            {% render 'icon', name: 'account', size: 22 %}
          </a>

          <button
            class="p-2 relative hover:bg-gray-50 rounded-lg transition-colors"
            @click="$store.cart.open()"
            aria-label="{{ 'accessibility.open_cart' | t }}"
          >
            {% render 'icon', name: 'cart', size: 22 %}
            <span
              x-show="$store.cart.itemCount > 0"
              x-text="$store.cart.itemCount"
              class="absolute -top-0.5 -right-0.5 bg-accent text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center"
              x-cloak
            ></span>
          </button>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ===================== MOBILE MENU ===================== {%- endcomment -%}
  <div
    class="fixed inset-0 z-50 lg:hidden"
    x-show="mobileOpen"
    x-cloak
  >
    {%- comment -%} Backdrop {%- endcomment -%}
    <div
      class="absolute inset-0 bg-black/40"
      x-show="mobileOpen"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      @click="mobileOpen = false"
    ></div>

    {%- comment -%} Drawer {%- endcomment -%}
    <div
      class="absolute left-0 top-0 bottom-0 w-full max-w-sm bg-white shadow-2xl flex flex-col overflow-hidden"
      x-show="mobileOpen"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="-translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="-translate-x-full"
      @keydown.escape.window="mobileOpen = false"
    >
      {%- comment -%} Close button {%- endcomment -%}
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        {%- if settings.logo != blank -%}
          {% render 'image', image: settings.logo, alt: shop.name, width: 100, class: 'h-7 w-auto' %}
        {%- else -%}
          <span class="font-heading font-bold text-lg">{{ shop.name }}</span>
        {%- endif -%}
        <button @click="mobileOpen = false" class="p-2 hover:bg-gray-50 rounded-lg" aria-label="{{ 'accessibility.close_menu' | t }}">
          {% render 'icon', name: 'close', size: 22 %}
        </button>
      </div>

      {%- comment -%} Navigation wrapper with level transitions {%- endcomment -%}
      <div class="flex-1 overflow-y-auto relative">

        {%- comment -%} Level 0: Main menu items {%- endcomment -%}
        <div
          class="absolute inset-0 overflow-y-auto transition-transform duration-300"
          :class="mobileLevel > 0 ? '-translate-x-full' : 'translate-x-0'"
        >
          <nav class="py-4" aria-label="Mobile navigation">
            <ul>
              {%- for link in section.settings.menu.links -%}
                <li>
                  {%- if link.links.size > 0 -%}
                    <button
                      class="flex items-center justify-between w-full px-5 py-3.5 text-[15px] font-medium hover:bg-gray-50 transition-colors"
                      @click="mobileLevel = 1; mobileActiveMenu = '{{ link.title | handleize }}'"
                    >
                      {{ link.title }}
                      {% render 'icon', name: 'chevron-right', size: 18 %}
                    </button>
                  {%- else -%}
                    <a href="{{ link.url }}" class="block px-5 py-3.5 text-[15px] font-medium hover:bg-gray-50 transition-colors">
                      {{ link.title }}
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>

            {%- comment -%} Secondary links {%- endcomment -%}
            {%- if section.settings.mobile_secondary_menu != blank -%}
              <div class="mt-4 pt-4 border-t border-gray-100 px-5">
                {%- for link in section.settings.mobile_secondary_menu.links -%}
                  <a href="{{ link.url }}" class="block py-2.5 text-sm text-gray-500 hover:text-primary transition-colors">
                    {{ link.title }}
                  </a>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- comment -%} Social links {%- endcomment -%}
            <div class="mt-6 px-5 flex items-center gap-4">
              {%- if settings.social_instagram != blank -%}
                <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" class="text-gray-400 hover:text-primary" aria-label="Instagram">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_tiktok != blank -%}
                <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" class="text-gray-400 hover:text-primary" aria-label="TikTok">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                </a>
              {%- endif -%}
            </div>
          </nav>
        </div>

        {%- comment -%} Level 1: Sub-menus (one per top-level item) {%- endcomment -%}
        {%- for link in section.settings.menu.links -%}
          {%- if link.links.size > 0 -%}
            <div
              class="absolute inset-0 overflow-y-auto transition-transform duration-300"
              :class="mobileLevel === 1 && mobileActiveMenu === '{{ link.title | handleize }}' ? 'translate-x-0' : 'translate-x-full'"
            >
              {%- comment -%} Back button {%- endcomment -%}
              <button
                class="flex items-center gap-2 w-full px-5 py-4 text-sm font-medium text-gray-500 hover:bg-gray-50 border-b border-gray-100"
                @click="mobileLevel = 0; mobileActiveMenu = null"
              >
                <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                Zurück
              </button>

              {%- comment -%} Category title {%- endcomment -%}
              <div class="px-5 py-4">
                <h3 class="text-lg font-heading font-bold">{{ link.title }}</h3>
              </div>

              {%- comment -%} Sub-links {%- endcomment -%}
              <ul class="px-5">
                {%- for child_link in link.links -%}
                  <li>
                    <a href="{{ child_link.url }}" class="block py-3 text-[15px] hover:text-accent transition-colors border-b border-gray-50">
                      {{ child_link.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>

              {%- comment -%} View All {%- endcomment -%}
              {%- if link.url != '#' -%}
                <div class="px-5 py-4">
                  <a href="{{ link.url }}" class="inline-flex items-center gap-1 text-sm font-medium text-accent">
                    Alle {{ link.title }} anzeigen
                    {% render 'icon', name: 'chevron-right', size: 14 %}
                  </a>
                </div>
              {%- endif -%}

              {%- comment -%} Category Image {%- endcomment -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'mega_menu_image' and block.settings.menu_title == link.title -%}
                  {%- if block.settings.image != blank -%}
                    <div class="px-5 pb-5">
                      <a href="{{ block.settings.image_link | default: link.url }}" class="block rounded-lg overflow-hidden relative aspect-[16/9]">
                        {% render 'image',
                          image: block.settings.image,
                          alt: block.settings.image_heading,
                          class: 'w-full h-full object-cover',
                          sizes: '350px'
                        %}
                        {%- if block.settings.image_heading != blank -%}
                          <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent flex items-end p-4">
                            <p class="text-white font-bold">{{ block.settings.image_heading }}</p>
                          </div>
                        {%- endif -%}
                      </a>
                    </div>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Kostenloser Versand ab 150€ | Made in Italy"
    },
    {
      "type": "url",
      "id": "announcement_link",
      "label": "Announcement Link"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Hauptmenü",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "mobile_secondary_menu",
      "label": "Mobile: Sekundäres Menü (z.B. Über uns, Kontakt)"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu_image",
      "name": "Mega Menu Bild",
      "settings": [
        {
          "type": "text",
          "id": "menu_title",
          "label": "Menüpunkt-Titel (muss exakt übereinstimmen)",
          "info": "Gib den exakten Titel des Hauptmenüpunkts ein, z.B. 'Sitzmöbel'"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        },
        {
          "type": "text",
          "id": "image_heading",
          "label": "Bild-Überschrift",
          "default": "Neue Kollektion"
        },
        {
          "type": "text",
          "id": "image_text",
          "label": "Bild-Text",
          "default": "Jetzt entdecken"
        },
        {
          "type": "url",
          "id": "image_link",
          "label": "Bild-Link"
        }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
