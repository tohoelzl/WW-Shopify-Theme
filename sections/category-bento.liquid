{%- comment -%}
  Bento Grid Category Section
  Displays collections in an asymmetric, visually striking grid layout.
  Large featured tiles + smaller tiles for visual hierarchy.
{%- endcomment -%}

<section class="py-16 lg:py-24">
  <div class="container">
    {%- if section.settings.subheading != blank -%}
      <p class="text-sm font-medium text-accent uppercase tracking-[0.2em] mb-2 {% if section.settings.center %}text-center{% endif %}">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="text-3xl lg:text-5xl font-heading font-bold mb-10 lg:mb-14 {% if section.settings.center %}text-center{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4 auto-rows-[180px] lg:auto-rows-[220px]">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        {%- liquid
          case block.settings.size
            when 'large'
              assign span_class = 'col-span-2 row-span-2'
            when 'wide'
              assign span_class = 'col-span-2 row-span-1'
            when 'tall'
              assign span_class = 'col-span-1 row-span-2'
            else
              assign span_class = 'col-span-1 row-span-1'
          endcase
        -%}

        <a
          href="{{ collection.url | default: block.settings.link | default: '#' }}"
          class="{{ span_class }} group relative rounded-xl overflow-hidden"
          {{ block.shopify_attributes }}
        >
          {%- liquid
            assign bento_image = block.settings.image
            unless bento_image
              assign bento_image = collection.image
            endunless
            unless bento_image
              if collection.products.size > 0
                assign bento_image = collection.products.first.featured_image
              endif
            endunless
          -%}
          {%- if bento_image -%}
            {% render 'image',
              image: bento_image,
              alt: block.settings.label | default: collection.title,
              class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-110',
              sizes: '(min-width: 1024px) 33vw, 50vw'
            %}
          {%- else -%}
            <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200"></div>
          {%- endif -%}

          {%- comment -%} Overlay + Label {%- endcomment -%}
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent transition-opacity duration-300">
            <div class="absolute bottom-0 left-0 right-0 p-4 lg:p-6">
              <h3 class="text-white font-heading font-bold text-lg lg:text-xl">
                {{ block.settings.label | default: collection.title | default: 'Kollektion' }}
              </h3>
              {%- if block.settings.description != blank -%}
                <p class="text-white/70 text-sm mt-1 hidden sm:block">{{ block.settings.description }}</p>
              {%- endif -%}
              <span class="inline-flex items-center gap-1 text-white/80 text-xs sm:text-sm mt-2 group-hover:text-white transition-colors">
                Entdecken
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
              </span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kategorie Bento Grid",
  "settings": [
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Kollektion" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Entdecke unsere Welt" },
    { "type": "checkbox", "id": "center", "label": "Zentrieren", "default": true }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategorie",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Kollektion" },
        { "type": "image_picker", "id": "image", "label": "Bild (überschreibt Kollektionsbild)" },
        { "type": "text", "id": "label", "label": "Label (überschreibt Kollektionsname)" },
        { "type": "text", "id": "description", "label": "Beschreibung" },
        { "type": "url", "id": "link", "label": "Link (überschreibt Kollektions-URL)" },
        {
          "type": "select",
          "id": "size",
          "label": "Kachel-Größe",
          "options": [
            { "value": "normal", "label": "Normal (1x1)" },
            { "value": "large", "label": "Groß (2x2)" },
            { "value": "wide", "label": "Breit (2x1)" },
            { "value": "tall", "label": "Hoch (1x2)" }
          ],
          "default": "normal"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Kategorie Bento Grid",
      "blocks": [
        { "type": "category", "settings": { "label": "Sitzmöbel", "size": "large" } },
        { "type": "category", "settings": { "label": "Tische", "size": "normal" } },
        { "type": "category", "settings": { "label": "Leuchten", "size": "normal" } },
        { "type": "category", "settings": { "label": "Bar & Gastro", "size": "wide" } },
        { "type": "category", "settings": { "label": "Deko", "size": "normal" } },
        { "type": "category", "settings": { "label": "Regale", "size": "normal" } }
      ]
    }
  ]
}
{% endschema %}
