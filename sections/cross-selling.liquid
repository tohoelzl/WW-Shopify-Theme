{%- comment -%}
  Cross-selling: Shows Shopify recommendations, falls back to
  products from the same collection if no recommendations exist.
{%- endcomment -%}

{%- liquid
  assign has_recommendations = false
  if recommendations.performed? and recommendations.products_count > 0
    assign has_recommendations = true
    assign cross_products = recommendations.products
  elsif product.collections.size > 0
    assign fallback_collection = product.collections.first
    assign cross_products = fallback_collection.products
  endif
-%}

{%- if cross_products.size > 0 -%}
<section class="py-12 lg:py-16">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="text-2xl lg:text-3xl font-heading font-bold mb-8">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
      {%- for item in cross_products limit: section.settings.products_count -%}
        {%- if item.id != product.id -%}
          {% render 'product-card', product: item %}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Cross-Selling",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Das könnte dir auch gefallen"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Anzahl Produkte",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Cross-Selling"
    }
  ]
}
{% endschema %}
