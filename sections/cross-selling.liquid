<section class="py-12 lg:py-16" x-data="{ products: [] }" x-init="
  fetch('/recommendations/products.json?product_id={{ product.id }}&limit={{ section.settings.products_count }}&section_id={{ section.id }}')
    .then(r => r.json())
    .then(data => { products = data.products })
    .catch(() => {})
">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="text-2xl lg:text-3xl font-heading font-bold mb-8">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- comment -%} Server-side fallback for SEO + no-JS {%- endcomment -%}
    {%- if recommendations.performed? and recommendations.products_count > 0 -%}
      <div class="cross-selling-slider splide" aria-label="{{ section.settings.heading }}">
        <div class="splide__track">
          <div class="splide__list">
            {%- for product in recommendations.products limit: section.settings.products_count -%}
              <div class="splide__slide">
                {% render 'product-card', product: product %}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>

      {{ 'splide-core.min.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'cross-selling.js' | asset_url }}" type="module" defer></script>
    {%- else -%}
      {%- comment -%} Placeholder when no recommendations available {%- endcomment -%}
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
        {%- for i in (1..4) -%}
          <div class="animate-pulse">
            <div class="aspect-square rounded bg-gray-100 mb-3"></div>
            <div class="h-3 bg-gray-100 rounded w-1/3 mb-2"></div>
            <div class="h-4 bg-gray-100 rounded w-2/3 mb-2"></div>
            <div class="h-4 bg-gray-100 rounded w-1/4"></div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cross-Selling",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Das könnte dir auch gefallen"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Anzahl Produkte",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Cross-Selling"
    }
  ]
}
{% endschema %}
