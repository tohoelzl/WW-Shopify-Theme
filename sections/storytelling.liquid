{%- comment -%}
  Storytelling Section — full-bleed image with overlay text.
  Used for "Made in Italy", sustainability messaging, brand story.
{%- endcomment -%}

<section class="relative overflow-hidden {% if section.settings.full_height %}min-h-[60vh] lg:min-h-[70vh]{% else %}py-20 lg:py-32{% endif %} flex items-center"
  {% if section.settings.full_height %}style="min-height: {{ section.settings.min_height }}vh"{% endif %}
>
  {%- if section.settings.image != blank -%}
    <div class="absolute inset-0" data-parallax-story>
      {% render 'image',
        image: section.settings.image,
        alt: section.settings.heading,
        class: 'w-full h-full object-cover',
        sizes: '100vw'
      %}
    </div>
  {%- endif -%}

  {%- if section.settings.video_url != blank -%}
    <video class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline>
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- endif -%}

  <div class="absolute inset-0 {{ section.settings.overlay_style }}"></div>

  <div class="container relative z-10">
    <div class="max-w-2xl {% if section.settings.content_position == 'center' %}mx-auto text-center{% elsif section.settings.content_position == 'right' %}ml-auto text-right{% endif %}">
      {%- if section.settings.subheading != blank -%}
        <p class="text-sm font-medium uppercase tracking-[0.2em] mb-4 {% if section.settings.text_color == 'light' %}text-white/70{% else %}text-accent{% endif %}">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="text-3xl sm:text-4xl lg:text-6xl font-heading font-bold leading-[1.1] mb-6 {% if section.settings.text_color == 'light' %}text-white{% else %}text-primary{% endif %}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="text-lg leading-relaxed mb-8 {% if section.settings.text_color == 'light' %}text-white/80{% else %}text-gray-600{% endif %} max-w-xl {% if section.settings.content_position == 'center' %}mx-auto{% elsif section.settings.content_position == 'right' %}ml-auto{% endif %}">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="inline-flex items-center px-8 py-4 font-medium rounded transition-colors text-sm uppercase tracking-wider {% if section.settings.text_color == 'light' %}bg-white text-primary hover:bg-gray-100{% else %}bg-primary text-white hover:opacity-90{% endif %}"
        >
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    const el = document.querySelector('[data-parallax-story]');
    if (!el || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const section = el.closest('section');
    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        window.addEventListener('scroll', parallax, { passive: true });
      } else {
        window.removeEventListener('scroll', parallax);
      }
    });
    function parallax() {
      const rect = section.getBoundingClientRect();
      const speed = 0.2;
      el.style.transform = 'translateY(' + (-rect.top * speed) + 'px)';
    }
    observer.observe(section);
  })();
</script>

{% schema %}
{
  "name": "Storytelling",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hintergrundbild" },
    { "type": "url", "id": "video_url", "label": "Video URL (MP4)" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Unsere Geschichte" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Made in Italy — mit Liebe zum Detail" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Jedes unserer Möbelstücke wird in Italien aus nachhaltigem Biokunststoff gefertigt. Wir verbinden traditionelles Handwerk mit innovativen Materialien für eine bessere Zukunft.</p>" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Mehr erfahren" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    {
      "type": "select", "id": "content_position", "label": "Content Position",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select", "id": "text_color", "label": "Textfarbe",
      "options": [
        { "value": "light", "label": "Weiß (auf dunklem Bild)" },
        { "value": "dark", "label": "Dunkel (auf hellem Bild)" }
      ],
      "default": "light"
    },
    {
      "type": "select", "id": "overlay_style", "label": "Overlay",
      "options": [
        { "value": "bg-black/40", "label": "Dunkel" },
        { "value": "bg-black/60", "label": "Sehr dunkel" },
        { "value": "bg-gradient-to-r from-black/70 to-transparent", "label": "Gradient Links" },
        { "value": "bg-gradient-to-l from-black/70 to-transparent", "label": "Gradient Rechts" },
        { "value": "", "label": "Kein Overlay" }
      ],
      "default": "bg-gradient-to-r from-black/70 to-transparent"
    },
    { "type": "checkbox", "id": "full_height", "label": "Volle Bildschirmhöhe", "default": true },
    { "type": "range", "id": "min_height", "label": "Mindesthöhe", "min": 40, "max": 100, "step": 5, "default": 65, "unit": "vh" }
  ],
  "presets": [{ "name": "Storytelling" }]
}
{% endschema %}
