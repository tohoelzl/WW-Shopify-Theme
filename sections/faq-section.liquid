{%- comment -%}
  FAQ Section — automatically shows FAQs based on current collection or page handle.
  No Metaobjects needed — all FAQ data is stored in snippets/faq-data.liquid.
  Schema.org FAQPage markup is generated via snippets/faq-schema-data.liquid.

  Handle mapping:
    Collections: stuehle, sessel, sofas, sitzbaenke, hocker, barhocker, liegen,
                 tische, couchtische, beistelltische, stehtische,
                 tischlampen, stehlampen, haengelampen, wandleuchten,
                 bartheken, bartresen, eiskuebel,
                 regale, flaschenregale, raumteiler,
                 blumentoepfe, vasen, spiegel, skulpturen, tabletts, kissen
    Pages:       sitzmoebel, page-tische, leuchten, bar-gastro, aufbewahrung, deko, allgemein, versand
{%- endcomment -%}

{%- liquid
  assign faq_handle = ''

  if collection
    assign faq_handle = collection.handle
  elsif page
    assign faq_handle = page.handle
  endif

  if request.page_type == 'product' and product.collections.size > 0
    assign faq_handle = product.collections.first.handle
  endif
-%}

{%- if faq_handle != blank -%}

  {%- comment -%} Check if we have FAQ content for this handle by capturing output {%- endcomment -%}
  {%- capture faq_output -%}{% render 'faq-data', faq_handle: faq_handle %}{%- endcapture -%}

  {%- if faq_output != blank -%}
    {% render 'faq-schema-data', faq_handle: faq_handle %}

    <section class="py-12 lg:py-16">
      <div class="container max-w-3xl">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold mb-8 text-center">
          {{ section.settings.heading | default: 'Häufige Fragen' }}
        </h2>

        <div class="space-y-0 border-t border-gray-100">
          {{ faq_output }}
        </div>
      </div>
    </section>
  {%- endif -%}

{%- endif -%}

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Häufige Fragen"
    }
  ],
  "presets": [
    {
      "name": "FAQ"
    }
  ]
}
{% endschema %}
