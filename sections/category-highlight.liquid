{%- comment -%}
  Category Highlight Section
  Shows a single category with large image, description, subcategory links, and CTA.
  Use multiple times on homepage for different categories.
{%- endcomment -%}

{%- assign collection = section.settings.collection -%}

<section class="py-16 lg:py-24 {% if section.settings.background == 'dark' %}bg-primary text-white{% elsif section.settings.background == 'subtle' %}bg-gray-50{% endif %}">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">

      {%- comment -%} Image side {%- endcomment -%}
      <div class="{% if section.settings.image_position == 'right' %}lg:order-2{% endif %}">
        <a href="{{ collection.url | default: section.settings.button_link }}" class="block group rounded-2xl overflow-hidden relative aspect-[4/3]">
          {%- if section.settings.image != blank -%}
            {% render 'image',
              image: section.settings.image,
              alt: section.settings.heading,
              class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-105',
              sizes: '(min-width: 1024px) 50vw, 100vw'
            %}
          {%- elsif collection.image -%}
            {% render 'image',
              image: collection.image,
              alt: collection.title,
              class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-105',
              sizes: '(min-width: 1024px) 50vw, 100vw'
            %}
          {%- else -%}
            <div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-300"></div>
          {%- endif -%}

          {%- comment -%} Optional badge overlay {%- endcomment -%}
          {%- if section.settings.badge_text != blank -%}
            <div class="absolute top-4 left-4 bg-accent text-white text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full">
              {{ section.settings.badge_text }}
            </div>
          {%- endif -%}
        </a>
      </div>

      {%- comment -%} Content side {%- endcomment -%}
      <div>
        {%- if section.settings.subheading != blank -%}
          <p class="text-sm font-medium uppercase tracking-[0.2em] mb-3 {% if section.settings.background == 'dark' %}text-white/60{% else %}text-accent{% endif %}">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="text-3xl lg:text-5xl font-heading font-bold leading-tight mb-4">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="text-lg leading-relaxed mb-8 {% if section.settings.background == 'dark' %}text-white/70{% else %}text-gray-600{% endif %}">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        {%- comment -%} Subcategory links grid {%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          <div class="grid grid-cols-2 gap-3 mb-8">
            {%- for block in section.blocks -%}
              {%- assign sub_collection = block.settings.collection -%}
              <a
                href="{{ sub_collection.url | default: block.settings.link | default: '#' }}"
                class="flex items-center gap-3 p-3 rounded-xl border transition-all duration-200 hover:shadow-md hover:-translate-y-0.5 {% if section.settings.background == 'dark' %}border-white/10 hover:border-white/30 hover:bg-white/5{% else %}border-gray-200 hover:border-accent/30 bg-white{% endif %}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.icon_image != blank -%}
                  {% render 'image',
                    image: block.settings.icon_image,
                    alt: block.settings.title,
                    class: 'w-10 h-10 rounded-lg object-cover flex-shrink-0',
                    width: 40
                  %}
                {%- else -%}
                  <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
                    {% render 'icon', name: 'chevron-right', size: 18 %}
                  </div>
                {%- endif -%}
                <div class="min-w-0">
                  <p class="text-sm font-medium truncate">{{ block.settings.title | default: sub_collection.title | default: 'Kategorie' }}</p>
                  {%- if sub_collection.products_count -%}
                    <p class="text-xs {% if section.settings.background == 'dark' %}text-white/40{% else %}text-gray-400{% endif %}">{{ sub_collection.products_count }} Produkte</p>
                  {%- endif -%}
                </div>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} CTA Button {%- endcomment -%}
        {%- if section.settings.button_text != blank -%}
          <a
            href="{{ collection.url | default: section.settings.button_link | default: '#' }}"
            class="inline-flex items-center gap-2 px-8 py-4 font-medium rounded-lg text-sm uppercase tracking-wider transition-all duration-200 {% if section.settings.background == 'dark' %}bg-white text-primary hover:bg-gray-100{% else %}bg-primary text-white hover:opacity-90{% endif %}"
          >
            {{ section.settings.button_text }}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kategorie Highlight",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild (überschreibt Kollektionsbild)"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Kollektion"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Sitzmöbel"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Beschreibung",
      "default": "<p>Entdecke unsere Auswahl an hochwertigen Sitzmöbeln aus nachhaltigem Biokunststoff — zeitloses Design, Made in Italy.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Alle Sitzmöbel entdecken"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text (optional)",
      "info": "z.B. 'Neu', 'Bestseller', 'Sale'"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Bild-Position",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Hintergrund",
      "options": [
        { "value": "white", "label": "Weiß" },
        { "value": "subtle", "label": "Hellgrau" },
        { "value": "dark", "label": "Dunkel" }
      ],
      "default": "white"
    }
  ],
  "blocks": [
    {
      "type": "subcategory",
      "name": "Unterkategorie",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Kollektion"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel (überschreibt Kollektionsname)"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon/Bild (40x40)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (überschreibt Kollektions-URL)"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Kategorie Highlight",
      "blocks": [
        { "type": "subcategory", "settings": { "title": "Stühle" } },
        { "type": "subcategory", "settings": { "title": "Sessel" } },
        { "type": "subcategory", "settings": { "title": "Sofas" } },
        { "type": "subcategory", "settings": { "title": "Hocker" } }
      ]
    }
  ]
}
{% endschema %}
