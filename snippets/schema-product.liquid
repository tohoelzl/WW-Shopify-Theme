{%- comment -%}
  Schema.org Product markup.
  Usage: {% render 'schema-product', product: product %}
{%- endcomment -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "url": {{ request.origin | append: product.url | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  {%- if product.featured_image -%}
  "image": [
    {{ product.featured_image | image_url: width: 1200 | json }}
    {%- for image in product.images offset: 1 limit: 4 -%}
      ,{{ image | image_url: width: 1200 | json }}
    {%- endfor -%}
  ],
  {%- endif -%}
  {%- if product.variants.first.barcode != blank -%}
  "gtin": {{ product.variants.first.barcode | json }},
  {%- endif -%}
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": {{ product.price_min | money_without_currency | json }},
    "highPrice": {{ product.price_max | money_without_currency | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
    "url": {{ request.origin | append: product.url | json }},
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    },
    "offerCount": {{ product.variants.size }}
    {%- if product.variants.first.sku != blank -%}
    ,"sku": {{ product.variants.first.sku | json }}
    {%- endif -%}
  }
}
</script>
