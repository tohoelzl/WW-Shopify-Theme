{%- liquid
  assign img_sizes = sizes | default: '100vw'
  assign img_width = width | default: 1200
  assign img_lazy = lazy | default: true
  if priority
    assign img_lazy = false
  endif
  assign img_class = class | default: ''
  assign img_alt = alt | default: ''
  assign srcset_widths = '375,640,768,1024,1200,1600' | split: ','
-%}

{%- if image != blank -%}
  {%- liquid
    assign img_height = height | default: image.height
  -%}
  <img
    src="{{ image | image_url: width: img_width }}"
    srcset="{%- for w in srcset_widths -%}{{ image | image_url: width: w }} {{ w }}w{%- unless forloop.last -%}, {%- endunless -%}{%- endfor -%}"
    sizes="{{ img_sizes }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    alt="{{ img_alt | escape }}"
    {%- if img_class != '' %} class="{{ img_class }}"{% endif %}
    {%- if img_lazy %} loading="lazy" decoding="async"{% endif %}
    {%- if priority %} fetchpriority="high"{% endif %}
  >
{%- else -%}
  <div class="bg-secondary {{ img_class }}" style="aspect-ratio: 1/1;"></div>
{%- endif -%}
