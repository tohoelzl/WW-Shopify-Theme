{%- comment -%}
  Upsell products in cart drawer.
  Loaded dynamically via Alpine.js fetch.
{%- endcomment -%}

<div
  class="px-4 py-4 border-t border-gray-100"
  x-data="{ upsells: [] }"
  x-init="
    if (window.themeSettings.cartUpsellEnabled && $store.cart.items.length > 0) {
      const productId = $store.cart.items[0].product_id;
      fetch('/recommendations/products.json?product_id=' + productId + '&limit=4')
        .then(r => r.json())
        .then(data => { upsells = data.products || [] })
        .catch(() => {});
    }
  "
  x-show="upsells.length > 0"
  x-cloak
>
  <p class="text-sm font-medium mb-3">{{ 'cart.recommended' | t }}</p>
  <div class="flex gap-3 overflow-x-auto pb-2 snap-x snap-mandatory scrollbar-hide">
    <template x-for="item in upsells" :key="item.id">
      <div class="flex-shrink-0 snap-start w-28">
        <a :href="item.url" class="block">
          <div class="aspect-square rounded bg-gray-50 overflow-hidden mb-2">
            <img
              :src="item.featured_image ? item.featured_image.replace('.jpg', '_200x.jpg').replace('.png', '_200x.png') : ''"
              :alt="item.title"
              class="w-full h-full object-cover"
              width="112"
              height="112"
              loading="lazy"
            >
          </div>
          <p class="text-xs line-clamp-2 mb-1" x-text="item.title"></p>
          <p class="text-xs font-medium" x-text="(item.price / 100).toFixed(2).replace('.', ',') + ' €'"></p>
        </a>
      </div>
    </template>
  </div>
</div>
