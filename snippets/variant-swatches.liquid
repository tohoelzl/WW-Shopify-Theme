{%- comment -%}
  Variant swatches component.
  Usage: {% render 'variant-swatches', product: product %}
{%- endcomment -%}

{%- for option in product.options_with_values -%}
  <div class="mb-4" x-data>
    <p class="text-sm font-medium mb-2">
      {{ option.name }}:
      <span class="font-normal text-gray-500" x-text="$store.productForm?.selectedOptions?.['{{ option.name }}'] || '{{ option.selected_value }}'"></span>
    </p>

    <div class="flex flex-wrap gap-2">
      {%- for value in option.values -%}
        {%- liquid
          assign option_index = 'option' | append: option.position
          assign is_color = false
          assign option_name_lower = option.name | downcase
          if option_name_lower == 'farbe' or option_name_lower == 'color' or option_name_lower == 'colour'
            assign is_color = true
          endif
        -%}

        {%- if is_color -%}
          {%- comment -%} Find the variant image for this color {%- endcomment -%}
          {%- assign swatch_image = nil -%}
          {%- for variant in product.variants -%}
            {%- if variant[option_index] == value and variant.featured_image -%}
              {%- assign swatch_image = variant.featured_image -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          <button
            type="button"
            class="w-10 h-10 rounded-full border-2 overflow-hidden transition-all duration-200 hover:scale-110 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
            :class="$store.productForm?.selectedOptions?.['{{ option.name }}'] === '{{ value | escape }}' ? 'border-primary ring-1 ring-primary' : 'border-gray-200'"
            @click="$dispatch('option:change', { name: '{{ option.name }}', value: '{{ value | escape }}' })"
            title="{{ value }}"
            aria-label="{{ option.name }}: {{ value }}"
          >
            {%- if swatch_image -%}
              <img
                src="{{ swatch_image | image_url: width: 80 }}"
                alt="{{ value }}"
                width="40"
                height="40"
                class="w-full h-full object-cover"
                loading="lazy"
              >
            {%- else -%}
              <span class="block w-full h-full bg-gray-200" title="{{ value }}"></span>
            {%- endif -%}
          </button>
        {%- else -%}
          <button
            type="button"
            class="px-4 py-2 text-sm border rounded transition-colors duration-200 hover:border-primary focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
            :class="$store.productForm?.selectedOptions?.['{{ option.name }}'] === '{{ value | escape }}' ? 'border-primary bg-primary text-white' : 'border-gray-200 text-primary'"
            @click="$dispatch('option:change', { name: '{{ option.name }}', value: '{{ value | escape }}' })"
            aria-label="{{ option.name }}: {{ value }}"
          >
            {{ value }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endfor -%}
