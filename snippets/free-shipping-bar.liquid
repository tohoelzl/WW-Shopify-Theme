{%- comment -%}
  Free shipping progress bar.
  Rendered inside cart-drawer.liquid, driven by Alpine.js $store.cart.
{%- endcomment -%}

<div class="px-4 py-3 bg-gray-50" x-show="$store.cart.itemCount > 0">
  <div class="flex items-center justify-between text-sm mb-1.5">
    <template x-if="$store.cart.hasFreeShipping">
      <span class="text-accent font-medium">
        {% render 'icon', name: 'truck', size: 16 %}
        {{ 'cart.shipping_free' | t }} ✓
      </span>
    </template>
    <template x-if="!$store.cart.hasFreeShipping">
      <span class="text-gray-600" x-html="'{{ 'cart.shipping_remaining' | t }}'.replace('{{ amount }}', '<strong>' + $store.cart.freeShippingRemaining.toFixed(2).replace('.', ',') + ' €</strong>')">
      </span>
    </template>
  </div>
  <div class="w-full bg-gray-200 rounded-full h-1.5 overflow-hidden">
    <div
      class="h-full rounded-full transition-all duration-500 ease-out"
      :class="$store.cart.hasFreeShipping ? 'bg-accent' : 'bg-primary'"
      :style="'width: ' + $store.cart.freeShippingProgress + '%'"
    ></div>
  </div>
</div>
